#!/bin/sh
# Run Commitizen instead of default editor.
# Skip if a commit message is already provided (e.g. standard-version, --message flag)
# $2 is the commit source: 'message', 'template', 'merge', 'squash', 'commit'
# If it is set, a message already exists so we don't need Commitizen.
if [ -n "$2" ]; then
  exit 0
fi

if [ -e /dev/tty ] && exec < /dev/tty 2>/dev/null; then
  npx cz --hook || true
elif command -v winpty >/dev/null 2>&1; then
  winpty npx cz --hook || true
elif command -v npx >/dev/null 2>&1; then
  npx cz --hook || true
elif [ -x "./node_modules/.bin/cz" ]; then
  ./node_modules/.bin/cz --hook || true
elif [ -f "./node_modules/commitizen/bin/commitizen" ]; then
  node ./node_modules/commitizen/bin/commitizen --hook || true
else
  true
fi
